# Probe — environment configuration
#
# Probe supports 5 LLM providers. The easiest path is `probe setup`, which
# stores credentials encrypted under ~/.probe/credentials.json. Environment
# variables below are optional and override the encrypted store.
#
# Gemini is free — get a key at https://aistudio.google.com/apikey

# --- Primary: explicit provider + key ---
# Valid PROBE_PROVIDER values: gemini, anthropic, openai, groq, mistral
PROBE_PROVIDER=gemini
PROBE_API_KEY=your-api-key-here

# --- Legacy: backward compatible with existing Anthropic-only setups ---
# If set and PROBE_API_KEY is not, Probe auto-selects the "anthropic" provider.
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
